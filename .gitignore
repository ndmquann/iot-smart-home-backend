# ==========================================
# 1. SECURITY & CONFIGURATION
# ==========================================
# NEVER commit your secrets to version control!
.env
.env.*
*.pem
*.key

# ==========================================
# 2. PYTHON COMPILE & CACHE
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ==========================================
# 3. VIRTUAL ENVIRONMENTS
# ==========================================
env/
venv/
.env/
.venv/
env.bak/
venv.bak/

# ==========================================
# 4. DOCKER & DATABASE VOLUMES
# ==========================================
# Ignore local database data mapped from Docker containers
postgres_data/
pgdata/

# ==========================================
# 5. IDE & EDITOR SETTINGS
# ==========================================
.vscode/
.idea/
*.swp
*.swo
*~

# ==========================================
# 6. OS GENERATED FILES
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ==========================================
# 7. TESTING & LOGS
# ==========================================
*.log
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
.tox/

# ==========================================
# 8. BUILD & DISTRIBUTION
# ==========================================
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg